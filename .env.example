# Copy to .env.local and fill values. All vars REQUIRED to boot (validateEnv() fail-fast).

# Neon Postgres (Singapore region recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Better Auth — pad with random 32+ chars
BETTER_AUTH_SECRET=replace-with-32-plus-random-chars-here-xxxxxxx
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx
ALLOWED_EMAIL=you@example.com

# Email alerts (Brevo SMTP relay — free tier 300/day)
# SMTP & API → SMTP keys: BREVO_SMTP_USER is the login email; BREVO_SMTP_KEY is the generated SMTP key.
# ALERT_FROM_EMAIL must be a sender VERIFIED in Brevo (Senders → Add a sender → confirm). Can be your own Gmail; no domain/DNS needed.
# ALERT_TO_EMAIL is your inbox (the single destination).
BREVO_SMTP_USER=you@example.com
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=you@example.com
ALERT_TO_EMAIL=you@example.com

# Cron — pad with random 32+ chars
CRON_SECRET=replace-with-32-plus-random-chars-here-xxxxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
