# Copy to .env.local and fill values. All vars REQUIRED to boot (validateEnv() fail-fast).

# Neon Postgres (Singapore region recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Better Auth — pad with random 32+ chars
BETTER_AUTH_SECRET=replace-with-32-plus-random-chars-here-xxxxxxx
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx
ALLOWED_EMAIL=you@example.com

# Telegram (BotFather)
# pad with random 32+ chars (Telegram bot token format works as-is, longer than 32)
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_OWNER_USER_ID=123456789
TELEGRAM_DM_CHAT_ID=123456789

# Webhook + cron — pad with random 32+ chars
WEBHOOK_SECRET=replace-with-32-plus-random-chars-here-xxxxxxx
CRON_SECRET=replace-with-32-plus-random-chars-here-xxxxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
