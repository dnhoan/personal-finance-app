# better-auth@1.6.16 declares peerOptional drizzle-kit >=0.31.4 and
# drizzle-orm ^0.45.2, but the project pins the 0.30.x / 0.36.x lines (the
# lockfile was resolved against these). The conflict is a peerOptional mismatch
# only — the adapter works against the pinned versions. legacy-peer-deps keeps
# `npm ci` deterministic across local, CI, and the pre-commit hook.
legacy-peer-deps=true
